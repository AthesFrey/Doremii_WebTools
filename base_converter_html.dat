<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>进制转换器</title>
</head>

<body>
  <!-- 组件脚本 -->
  <script defer src="/wp-content/uploads/base-converter.js?v=202511A"></script>

  <!-- 进制转换器（标题与组件均居中，标题可上下挪） -->
  <!-- 只要改 --title-y：负数上移，正数下移 -->
  <div style="--title-y:0px; --title-gap:10px; max-width:520px; margin:0 auto; text-align:center;">
    <h2 style="
      font-size:22px;
      color:#32CD32;
      margin:0 0 var(--title-gap);
      transform: translateY(var(--title-y));
    ">
      进制转换器
    </h2>

    <doremii-base-converter
      accent="#32CD32"
      style="
        --card-bg:#f0fff0;       /* honeydew 颜色 */
        --card-border:#98FB98;   /* palegreen 颜色 */
        --text:#0f172a;          /* 深灰色文字 */
        --button-bg:#32CD32;     /* limegreen 按钮背景 */
        --button-fg:#ffffff;     /* 白色文字 */
        --result-bg:#32CD32;     /* limegreen 结果背景 */
        --result-fg:#ffffff;     /* 白色文字 */
        --hist-bg:#f0fff0;       /* honeydew 历史背景 */

        display:block;           /* 兜底为块级元素 */
        margin:0 auto;           /* 组件水平居中 */
        max-width:520px;         /* （可按需改为其他） */
      ">
    </doremii-base-converter>
  </div>

  <!-- 示例：把标题上移/下移（可删）
  <script>
    // 上移 12px：document.querySelector('div[style*="--title-y"]').style.setProperty('--title-y','-12px');
    // 下移 6px：document.querySelector('div[style*="--title-y"]').style.setProperty('--title-y','6px');
  </script>
  -->
</body>
</html>
